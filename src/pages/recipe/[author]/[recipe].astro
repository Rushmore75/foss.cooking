---
import type { GetStaticPaths } from 'astro';
import { render, type CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Base from '../../../partials/base.astro';
import Header from '../../../partials/header.astro';

export async function getAuthorNameOf(recipe: CollectionEntry<"recipe">) {
    const author = await getAuthorOf(recipe);
    if (author) {
        return author.data.name
    }
    // no author.json
    // This is just a vanity name, so we can doctor it.
    return recipe.id.split("/")[0].replaceAll('-', ' ')
}

export async function getAuthorOf(recipe: CollectionEntry<"recipe">) {
    const authorId = recipe.id.split("/")[0];
    return getEntry("authors", `${authorId}/author`);
}

// generate the page
export const getStaticPaths = (async () => {
    let all = await getCollection("recipe");
    return all.map(e => {
        let path = e.id as string;
        let parts = path.split('/');
        let author = parts[0]
        let recipe = parts[1]
        
        return ({
            params: {recipe: recipe, author: author},
            props: { article: e }
        })
    });
}) satisfies GetStaticPaths;

// produce the page
const { article } = Astro.props;
const { Content } = await render(article);
const {title, date, tags} = article.data;

const author = await getAuthorOf(article);
const author_url = author ? "/author/" + author?.id.split('/')[0] : undefined;
const author_name = await getAuthorNameOf(article);

---
<Base title={title} desc=`${title} by ${author_name}` author={author_name} >
    <div>
        <Header title={title} author_url={author_url} author_name={author_name}/>
        <hr>
        <article>
            <Content />
        </article>
		<hr>
        <h3>Tags</h3>
		<ul>	
			{tags.map(e => <li><a id=`tag-${e}` href=`/tag/${e}` >{e}</a></li>)}
		</ul>	
    </div>
</Base>
<style>
    article {
        max-width: 800px;
        width: 90%;
        margin: auto;
    }
    h3 {
        text-align: center;
        font-size: 1.5rem;
        margin: 0;
    }
    ul {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        padding: 0;
    }
    li {
        list-style: none;
        padding-left: 10px;
        padding-right: 10px;
    }
</style>
<!-- is:global is required to reach inside the Content element -->
<style is:global>
    li p {
        /* If someone's list has spaces around it in the markdown, it will put paragraph elements inside the list item */
        margin: 0;
    }
    img {
        width: 100%;
        max-width: 400px;
        max-height: 400px;
        margin: auto;
        margin-top: 20px;
        margin-bottom: 20px;
        display: block;
        border-radius: 10px;
    }
</style>
