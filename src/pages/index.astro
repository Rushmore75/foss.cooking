---
import { getCollection } from "astro:content"
import Head from "../partials/base.astro"
import Tagcloud from "../partials/tagcloud.astro";
import RecipeList from "../partials/recipeList.astro";

export async function getTags(): Promise<string[]> {
	let recipes = await getCollection("recipe");
	// Get all the tags from the recipes and
	// add them to a hashset so we don't get duplicates.
	let set: Set<string> = new Set();
	recipes.flatMap((i) => i.data.tags).map((f) => set.add(f))
	let tags = new Array;
	set.forEach((e) => tags.push(e))
	return tags;
}

let recipes = await getCollection("recipe");
recipes.sort((a,b) => b.data.date.getTime() - a.data.date.getTime());
recipes = recipes.filter((r,i) => i<10)

const tags = await getTags();
---
<Head title='Home' desc='The best cooking website for open-source recipes.'>
	<header>
		<h1>Welcome to <span>foss.cooking<span></h1>
		<h2>Making cooking fast, easy, foss</h2>
		<h2>🧑‍🍳🔥</h2>
	</header>
	<div id="searchContainer">
		<form method="GET" action="/search">
    		<input
				id="query"
				name="query"
				type="search"
				placeholder="search..." autofocus spellcheck="false" autocomplete="off">
		</form>
	</div>
	<hr>
	<div id="latest">
		<h2>Latest Recipes:</h2>
		<RecipeList items={recipes} numberedList={true}/>
	</div>
	<hr>
	<Tagcloud tags={tags} />
</Head>
<style>
	header {
		margin: 50px;
	}
	h1 {
		margin-top: 40px;
		margin-bottom: 0;
		font-size: 2.5rem;
	}
	h1,h2 {
		text-align: center;
	}
	h2 {
		margin: 10px;
		color: var(--second);
	}
	span {
		color: var(--primary);
	}
    input {
        font-size: 1.5rem;
        text-align: center;

        padding: 10px;
        padding-left: 20px;
        padding-right: 20px;

        border-radius: 10px;
        border: none;
    }
	#searchContainer {
        display: flex;
        flex-direction: column;
        align-items: center;
	}
	#latest {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	#latest h2 {
		color: var(--text)
	}
</style>
