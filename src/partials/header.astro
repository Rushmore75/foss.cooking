---

interface Props {
    title: string,
    author_url?: string | null,
}

const { title, author_url } = Astro.props;

---

<header>
    <h1>{title}</h1>
    <div id="links">
        <span><a href="/">Home</a></span>
        {
            author_url && (
                <span>
                    <a href={author_url}>Author</a>
                </span>
            )
        }
        <span><a id="back">Back</a></span>
    </div>
</header>
<style>
    header {
        display: flex;
        flex-direction: column;
        margin: 40px;
        align-items: center;
    }
    h1 {
        margin: 0;
        text-align: center;
    }
    #links {
        display: flex;
        gap: 0.5em;
    }
</style>