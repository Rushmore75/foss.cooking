---
interface Props {
    title: string;
    author_url?: string;
    author_name?: string;
}

const { title, author_url, author_name } = Astro.props;
---

<header>
    <h1>{title}</h1>
    {author_name && <cite>by {author_name}</cite>}
    <div id="links">
        <span><a href="/">Home</a></span>
        {
            author_url && (
                <span>
                    <a href={author_url}>Author</a>
                </span>
            )
        }
        <span><a id="back">Back</a></span>
    </div>
</header>
<style>
    header {
        display: flex;
        flex-direction: column;
        margin: 40px;
        align-items: center;
    }
    h1 {
        margin: 0;
        text-align: center;
    }
    #links {
        display: flex;
        gap: 0.5em;
    }
</style>
